{% extends "base.html.j2" %}
{% block title %}{{ post.title }} — {{ site_title }}{% endblock %}
{% block content %}
<article class="post-full">
    <h1>{{ post.title }}</h1>
    <div class="post-meta">
        <time datetime="{{ post.date }}">{{ post.date }}</time>
        <span class="author">by {{ post.author }}</span>
        {% if post.tags %}
        <span class="tags">
            {% for tag in post.tags %}
            <span class="tag">{{ tag }}</span>
            {% endfor %}
        </span>
        {% endif %}
        {% if post.run_id %}
        <span class="run-id">Run: {{ post.run_id }}</span>
        {% endif %}
    </div>
    <div class="post-content">
        {{ post.html_content() }}
    </div>
</article>
<p class="back-link"><a href="/">← Back to posts</a></p>
{% endblock %}
